</ul>
</div>
</section>

<footer>
© 2026 LPPM Universitas Potensi Utama | Portal OJS
</footer>

<script>
const slides=document.getElementById("slides");
let index=0,total=slides.children.length;
function showSlide(){
slides.style.transform="translateX("+(-index*100)+"%)";
}
function nextSlide(){index=(index+1)%total;showSlide();}
function prevSlide(){index=(index-1+total)%total;showSlide();}
setInterval(nextSlide,5000);
</script>

</body>
</html>
